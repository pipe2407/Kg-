<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Tu Universo, K. Johanna</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #000008;
    overflow: hidden;
    font-family: 'Georgia', serif;
    height: 100dvh;
    width: 100vw;
    touch-action: none;
  }

  canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
  }

  /* Nebula background layers */
  .nebula {
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.18;
    pointer-events: none;
    z-index: 1;
    animation: drift 20s ease-in-out infinite alternate;
  }
  .nebula-1 { width: 400px; height: 300px; background: radial-gradient(#7b2fff, #ff4fa3); top: -80px; left: -100px; animation-duration: 18s; }
  .nebula-2 { width: 350px; height: 350px; background: radial-gradient(#00c6ff, #5b2bff); bottom: -50px; right: -80px; animation-duration: 22s; animation-delay: -7s; }
  .nebula-3 { width: 250px; height: 200px; background: radial-gradient(#ff6ec7, #ffb347); top: 40%; left: 50%; transform: translateX(-50%); animation-duration: 25s; animation-delay: -12s; opacity: 0.1; }

  @keyframes drift {
    from { transform: translateY(0px) scale(1); }
    to   { transform: translateY(30px) scale(1.08); }
  }

  /* Intro overlay */
  #intro {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #000008;
    transition: opacity 1.5s ease;
  }
  #intro.fade-out { opacity: 0; pointer-events: none; }

  .intro-title {
    font-size: clamp(13px, 4vw, 18px);
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #a78bfa;
    margin-bottom: 12px;
    opacity: 0;
    animation: fadeUp 1s 0.3s forwards;
  }
  .intro-name {
    font-size: clamp(42px, 14vw, 72px);
    color: #fff;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1;
    opacity: 0;
    animation: fadeUp 1s 0.7s forwards;
    text-shadow: 0 0 60px rgba(167,139,250,0.6);
  }
  .intro-sub {
    font-size: clamp(12px, 3.5vw, 16px);
    color: #e879f9;
    letter-spacing: 0.2em;
    margin-top: 10px;
    opacity: 0;
    animation: fadeUp 1s 1.1s forwards;
    font-style: italic;
  }
  .intro-btn {
    margin-top: 52px;
    padding: 14px 40px;
    border: 1px solid rgba(167,139,250,0.5);
    border-radius: 40px;
    background: transparent;
    color: #c4b5fd;
    font-size: 14px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    opacity: 0;
    animation: fadeUp 1s 1.6s forwards;
    transition: background 0.3s, color 0.3s, box-shadow 0.3s;
    -webkit-tap-highlight-color: transparent;
  }
  .intro-btn:active {
    background: rgba(167,139,250,0.2);
    box-shadow: 0 0 30px rgba(167,139,250,0.3);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Main scene */
  #scene {
    position: fixed;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 1.5s ease;
    pointer-events: none;
  }
  #scene.visible {
    opacity: 1;
    pointer-events: all;
  }

  /* Planet */
  .planet-wrap {
    position: relative;
    width: 200px;
    height: 200px;
    margin-bottom: 40px;
  }

  .planet {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%,
      #e0c3fc 0%,
      #9b59b6 30%,
      #4a0080 65%,
      #1a0030 100%
    );
    box-shadow:
      0 0 60px rgba(155,89,182,0.5),
      0 0 120px rgba(155,89,182,0.2),
      inset -20px -20px 40px rgba(0,0,0,0.5);
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    animation: rotatePlanet 20s linear infinite;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .planet::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 65% 30%,
      rgba(255,255,255,0.18) 0%,
      transparent 50%
    );
  }

  @keyframes rotatePlanet {
    from { box-shadow: 0 0 60px rgba(155,89,182,0.5), 0 0 120px rgba(155,89,182,0.2), inset -20px -20px 40px rgba(0,0,0,0.5); }
    50%  { box-shadow: 0 0 80px rgba(232,121,249,0.6), 0 0 140px rgba(232,121,249,0.25), inset -20px -20px 40px rgba(0,0,0,0.5); }
    to   { box-shadow: 0 0 60px rgba(155,89,182,0.5), 0 0 120px rgba(155,89,182,0.2), inset -20px -20px 40px rgba(0,0,0,0.5); }
  }

  /* Ring */
  .ring {
    position: absolute;
    top: 50%; left: 50%;
    width: 220px;
    height: 50px;
    transform: translate(-50%, -50%) rotateX(75deg);
    border-radius: 50%;
    border: 12px solid transparent;
    background: transparent;
    border-top-color: rgba(196,165,250,0.35);
    border-bottom-color: rgba(196,165,250,0.15);
    animation: spinRing 12s linear infinite;
    pointer-events: none;
  }

  @keyframes spinRing {
    from { transform: translate(-50%, -50%) rotateX(75deg) rotateZ(0deg); }
    to   { transform: translate(-50%, -50%) rotateX(75deg) rotateZ(360deg); }
  }

  /* Orbiting moon */
  .orbit {
    position: absolute;
    top: 50%; left: 50%;
    width: 190px;
    height: 190px;
    transform: translate(-50%, -50%);
    animation: orbitMoon 8s linear infinite;
    pointer-events: none;
  }
  .moon {
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #fff 0%, #c4b5fd 40%, #7c3aed 100%);
    box-shadow: 0 0 12px rgba(196,181,253,0.8);
  }
  @keyframes orbitMoon {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* Message card */
  .msg-card {
    background: rgba(15, 5, 30, 0.75);
    border: 1px solid rgba(167,139,250,0.25);
    border-radius: 20px;
    padding: 28px 32px;
    max-width: 340px;
    width: 88vw;
    text-align: center;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .msg-card.show {
    opacity: 1;
    transform: translateY(0);
  }

  .msg-eyebrow {
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #a78bfa;
    margin-bottom: 12px;
  }
  .msg-quote {
    font-size: clamp(17px, 4.8vw, 22px);
    color: #f3e8ff;
    line-height: 1.55;
    font-style: italic;
    font-weight: 400;
  }
  .msg-author {
    margin-top: 18px;
    font-size: 12px;
    letter-spacing: 0.15em;
    color: #e879f9;
    text-transform: uppercase;
  }

  /* Tap hint */
  .tap-hint {
    position: fixed;
    bottom: 48px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    letter-spacing: 0.25em;
    color: rgba(167,139,250,0.4);
    text-transform: uppercase;
    animation: pulse 3s ease-in-out infinite;
    z-index: 10;
    white-space: nowrap;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.9; }
  }

  /* Particles burst */
  .burst {
    position: fixed;
    pointer-events: none;
    z-index: 50;
  }
  .burst-particle {
    position: absolute;
    width: 4px; height: 4px;
    border-radius: 50%;
    animation: burstAnim 1s ease-out forwards;
  }
  @keyframes burstAnim {
    0%   { transform: translate(0,0) scale(1); opacity: 1; }
    100% { transform: translate(var(--dx), var(--dy)) scale(0); opacity: 0; }
  }
</style>
</head>
<body>

<canvas id="stars"></canvas>
<div class="nebula nebula-1"></div>
<div class="nebula nebula-2"></div>
<div class="nebula nebula-3"></div>

<!-- Intro -->
<div id="intro">
  <p class="intro-title">Un universo</p>
  <h1 class="intro-name">Johanna</h1>
  <p class="intro-sub">K. Johanna</p>
  <button class="intro-btn" id="enterBtn">Entrar al universo</button>
</div>

<!-- Scene -->
<div id="scene">
  <div class="planet-wrap" id="planetWrap">
    <div class="ring"></div>
    <div class="orbit"><div class="moon"></div></div>
    <div class="planet" id="planet"></div>
  </div>

  <div class="msg-card" id="msgCard">
    <p class="msg-eyebrow">Tu fe en nosotros</p>
    <p class="msg-quote" id="msgQuote">"Eres la pieza que le faltaba a mi universo."</p>
    <p class="msg-author">— K. Johanna</p>
  </div>
</div>

<p class="tap-hint" id="tapHint" style="display:none">Toca el planeta ✦</p>

<script>
// ── Stars canvas ──────────────────────────────────────────────
const canvas = document.getElementById('stars');
const ctx = canvas.getContext('2d');
let stars = [];

function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  buildStars();
}

function buildStars() {
  stars = [];
  const n = Math.floor((canvas.width * canvas.height) / 2200);
  for (let i = 0; i < n; i++) {
    stars.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      r: Math.random() * 1.4 + 0.3,
      a: Math.random(),
      da: (Math.random() - 0.5) * 0.008,
      speed: Math.random() * 0.06 + 0.01,
      vy: -(Math.random() * 0.12 + 0.02),
    });
  }
}

function drawStars() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  for (const s of stars) {
    s.a += s.da;
    if (s.a <= 0 || s.a >= 1) s.da *= -1;
    s.y += s.vy;
    if (s.y < -2) { s.y = canvas.height + 2; s.x = Math.random() * canvas.width; }
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(220,210,255,${s.a})`;
    ctx.fill();
  }
  requestAnimationFrame(drawStars);
}

window.addEventListener('resize', resize);
resize();
drawStars();

// ── Messages ──────────────────────────────────────────────────
const messages = [
  "Eres la pieza que le faltaba a mi universo.",
  "Mientras otros solo reaccionan historias... yo te programé un universo.",
  "Tu fe en nosotros es algo que atesoro profundamente.",
  "Cada estrella aquí tiene tu nombre.",
  "El universo entero conspira para que estés aquí.",
  "Eres mi coordenada favorita en el espacio.",
  "Si el cosmos tuviera un centro, serías tú.",
  "Yo acá con ganas de darte un besito, pero tú tan lejos.",
  "Con la mujer correcta, nada va a detenerme.",
  "Invencibles juntos.",
  "Ella sabía que él sabía, que algún día vendría a buscarla.",
  "Iluminas hasta la esquina más oscura de mi mundo.",
  "No busco a nadie más. Solo a ti, siempre a ti.",
  "Eres el tipo de persona que uno no quiere dejar ir.",
  "Mi universo empezó cuando apareciste tú.",
  "La distancia no cambia lo que siento. Solo lo hace más intenso.",
  "Eres mi lugar favorito sin coordenadas.",
  "Cada vez que te pienso, se me olvida el resto del universo.",
  "No sé cuántas estrellas hay, pero sí sé que ninguna brilla como tú.",
  "Hay personas que llegan y reordenan todo. Tú fuiste una de esas.",
  "Te elegiría en cualquier universo paralelo, en cualquier línea del tiempo.",
  "No te busqué. Simplemente apareciste y ya no supe imaginar el mundo sin ti.",
  "Eres la razón por la que creo que algunas cosas no son coincidencia.",
  "Me gusta quien soy cuando estoy contigo.",
  "Si existiera un mapa del universo, tu nombre estaría marcado como destino.",
  "Pienso en ti y de repente todo tiene más sentido.",
  "Contigo el tiempo pasa diferente. Más rápido cuando quiero que se quede.",
  "Hay una versión de mí que solo existe cuando estás cerca.",
  "Quisiera pausar algunos momentos contigo y vivirlos una y otra vez.",
  "No te prometo el mundo. Te programé uno solo para ti.",
  "Eres la única notificación que nunca silencio.",
  "Me quedé sin palabras el día que llegaste. Y eso no me pasa casi nunca.",
  "Ojalá pudieras ver lo especial que eres desde mis ojos.",
  "El universo es enorme, pero contigo cabe en un solo cuarto.",
  "Cada conversación contigo es mi parte favorita del día.",
  "Tú no eres un capítulo. Eres el libro entero.",
  "A veces no necesito hacer nada extraordinario. Solo estar contigo ya es suficiente.",
  "Floreces en la gente que te quiere bien. Y yo quiero quererte muy bien.",
  "El día que te conocí, algo en mí supo que esto iba a importar.",
];
messages.sort(() => Math.random() - 0.5);
let msgIndex = 0;

// ── Intro → Scene ─────────────────────────────────────────────
document.getElementById('enterBtn').addEventListener('click', () => {
  const intro = document.getElementById('intro');
  intro.classList.add('fade-out');
  setTimeout(() => {
    intro.style.display = 'none';
    const scene = document.getElementById('scene');
    scene.classList.add('visible');
    setTimeout(() => {
      document.getElementById('msgCard').classList.add('show');
      document.getElementById('tapHint').style.display = 'block';
    }, 400);
  }, 1500);
});

// ── Planet tap ────────────────────────────────────────────────
document.getElementById('planet').addEventListener('click', function(e) {
  // Cycle message
  msgIndex = (msgIndex + 1) % messages.length;
  const card = document.getElementById('msgCard');
  const quote = document.getElementById('msgQuote');
  card.classList.remove('show');
  setTimeout(() => {
    quote.textContent = `"${messages[msgIndex]}"`;
    card.classList.add('show');
  }, 400);

  // Burst
  spawnBurst(e.clientX, e.clientY);
});

function spawnBurst(cx, cy) {
  const container = document.createElement('div');
  container.className = 'burst';
  container.style.left = cx + 'px';
  container.style.top = cy + 'px';
  document.body.appendChild(container);

  const colors = ['#c4b5fd','#e879f9','#f9a8d4','#93c5fd','#ffffff'];
  const count = 20;
  for (let i = 0; i < count; i++) {
    const p = document.createElement('div');
    p.className = 'burst-particle';
    const angle = (i / count) * Math.PI * 2;
    const dist = 50 + Math.random() * 60;
    p.style.setProperty('--dx', Math.cos(angle) * dist + 'px');
    p.style.setProperty('--dy', Math.sin(angle) * dist + 'px');
    p.style.background = colors[i % colors.length];
    p.style.animationDelay = Math.random() * 0.1 + 's';
    container.appendChild(p);
  }
  setTimeout(() => container.remove(), 1200);
}

// ── Parallax tilt (gyro or pointer) ──────────────────────────
const wrap = document.getElementById('planetWrap');
let tiltX = 0, tiltY = 0;

function applyTilt(rx, ry) {
  tiltX += (ry * 18 - tiltX) * 0.08;
  tiltY += (rx * 18 - tiltY) * 0.08;
  wrap.style.transform = `rotateX(${-tiltX}deg) rotateY(${tiltY}deg)`;
  requestAnimationFrame(() => applyTilt(rx, ry));
}

if (window.DeviceOrientationEvent) {
  let lastBeta = 0, lastGamma = 0;
  window.addEventListener('deviceorientation', (e) => {
    lastBeta  = (e.beta  || 0) / 90;
    lastGamma = (e.gamma || 0) / 90;
    wrap.style.transform = `rotateX(${-lastBeta * 12}deg) rotateY(${lastGamma * 12}deg)`;
  });
}

window.addEventListener('mousemove', (e) => {
  const rx = (e.clientX / window.innerWidth  - 0.5) * 2;
  const ry = (e.clientY / window.innerHeight - 0.5) * 2;
  wrap.style.transform = `rotateX(${-ry * 12}deg) rotateY(${rx * 12}deg)`;
});
</script>
</body>
</html>
